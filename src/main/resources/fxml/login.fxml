<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15" prefWidth="400" prefHeight="300"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="realestate.controller.LoginController">
    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
    <Label text="REPMS Login" style="-fx-font-size: 18; -fx-front-weight: bold;"/>
    <TextField fx:id="usernameField" promptText="Username" maxWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250"/>

    <Label fx:id="errorLabel" textFill="RED"/>
    <Button text="Login" onAction="#handleLogin" defaultButton="true"/>

</VBox>


