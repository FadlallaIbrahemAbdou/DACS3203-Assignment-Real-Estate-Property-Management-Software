<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" prefWidth="750" prefHeight="550"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="realestate.controller.StaffController">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
    <Label text="Staff Management" style="-fx-font-size:16; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="fullNameField" promptText="Full Name" prefWidth="150"/>
        <TextField fx:id="usernameField" promptText="User name" prefWidth="120"/>
        <TextField fx:id="emailField" promptText="Email" prefWidth="150"/>
        <PasswordField fx:id="passwordField" promptText="Password" prefWidth="120"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Add Staff" onAction="#handleAdd"/>
        <Button text="Update" onAction="#handleUpdate"/>
        <Button text="Deactivate" onAction="#handleDeactivate"/>

    </HBox>

    <Label fx:id="messageLabel" textFill="DARKBLUE"/>

    <TableView fx:id="staffTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colFullName" text="Full Name" prefWidth="150"/>
            <TableColumn fx:id="colUsername" text="Username" prefWidth="120"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>

        </columns>
    </TableView>

    <Button text="Back to Dashboard" onAction="#handleBack"/>

</VBox>